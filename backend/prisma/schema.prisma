generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TrashType {
  organic
  mixed
  recyclable
  glass
}

model User {
  id                     Int                     @id @default(autoincrement())
  name                   String
  email                  String                  @unique
  passwordHash           String
  phoneNumber            String?
  active                 Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  address                UserAddress?
  collectionSchedules    CollectionSchedule[]
  notificationPreference NotificationPreference?
}

model UserAddress {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  street       String?
  neighborhood String?
  city         String
  country      String  @default("Malta")
  lat          Float    @default(0)
  lng          Float    @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model CollectionSchedule {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trashType TrashType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, trashType])
}

model NotificationPreference {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(false)
  notificationTime String
  notifyDayBefore  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
