generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TrashType {
  organic
  mixed
  recyclable
  glass
}

enum FrequencyType {
  weekly
  monthly
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  passwordHash        String
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  address             UserAddress?
  collectionSchedules CollectionSchedule[]
  alertConfig         AlertConfig?
}

model UserAddress {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  street       String
  neighborhood String?
  city         String
  state        String
  country      String
  lat          Float
  lng          Float
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model CollectionSchedule {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trashType     TrashType
  frequencyType FrequencyType
  weekdays      String[]      @default([])
  monthlyRules  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model AlertConfig {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled              Boolean  @default(true)
  daysBeforeCollection Int      @default(0)
  alertTime            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
